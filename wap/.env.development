# 开发环境配置
NODE_ENV=development

# 应用配置
VITE_APP_TITLE=彩票平台
VITE_APP_PORT=5173

# API配置
VITE_API_BASE_URL=/api/v1
VITE_API_TIMEOUT=30000

# 是否开启Mock
VITE_USE_MOCK=false

# 是否开启代理
VITE_USE_PROXY=true

VITE_PROXY_TARGET=http://127.0.0.1:8788

# WebSocket 服务地址
VITE_WS_URL=ws://127.0.0.1:8789/im-ws

# IM WebSocket 服务地址
VITE_IM_WS_URL=ws://127.0.0.1:8789/im-ws

# 是否开启HTTPS
VITE_HTTPS=false

# 是否开启压缩
VITE_BUILD_COMPRESS=gzip

# 是否删除console
VITE_DROP_CONSOLE=false
